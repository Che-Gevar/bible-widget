{
  "todayText": "Если же у кого из вас недостает мудрости...",
  "todayReference": "Иакова 1:5",
  "verses": [
    {
      "reference": "Иоанна 3:16",
      "text": "Ибо так возлюбил Бог мир, что отдал Сына Своего Единородного..."
    },
    {
      "reference": "Псалтирь 22:1",
      "text": "Господь — Пастырь мой; я ни в чем не буду нуждаться."
    },
    {
      "reference": "Притчи 3:5",
      "text": "Надейся на Господа всем сердцем твоим..."
    },
    {
      "reference": "Притчи 3:6",
      "text": "Во всех путях твоих познавай Его..."
    },
    {
      "reference": "Филиппийцам 4:13",
      "text": "Все могу в укрепляющем меня Иисусе Христе."
    },
    {
      "reference": "Римлянам 8:28",
      "text": "Любящим Бога все содействует ко благу..."
    },
    {
      "reference": "Матфея 11:28",
      "text": "Придите ко Мне все труждающиеся..."
    },
    {
      "reference": "Псалтирь 45:2",
      "text": "Бог нам прибежище и сила..."
    },
    {
      "reference": "Иеремия 29:11",
      "text": "Ибо только Я знаю намерения..."
    },
    {
      "reference": "Исаия 41:10",
      "text": "Не бойся, \nибо Я с тобою..."
    },
    {
      "reference": "Псалтирь 33:5",
      "text": "Я взыскал Господа, и Он услышал меня..."
    },
    {
      "reference": "2 Тимофею 1:7",
      "text": "Ибо дал нам Бог духа не боязни..."
    },
    {
      "reference": "Иисус Навин 1:9",
      "text": "Будь тверд и мужествен..."
    },
    {
      "reference": "Псалтирь 118:105",
      "text": "Слово Твое — светильник ноге моей..."
    },
    {
      "reference": "Римлянам 12:2",
      "text": "Не сообразуйтесь с веком сим..."
    },
    {
      "reference": "Матфея 6:33",
      "text": "Ищите же прежде Царства Божия..."
    },
    {
      "reference": "Иоанна 14:6",
      "text": "Я есмь путь и истина и жизнь..."
    },
    {
      "reference": "Псалтирь 90:1",
      "text": "Живущий под кровом Всевышнего..."
    },
    {
      "reference": "Евреям 11:1",
      "text": "Вера же есть осуществление ожидаемого..."
    },
    {
      "reference": "Иакова 1:5",
      "text": "Если же у кого из вас недостает мудрости..."
    },
    {
      "reference": "Галатам 5:22",
      "text": "Плод же духа: любовь, радость, мир..."
    },
    {
      "reference": "Колоссянам 3:23",
      "text": "И все, что делаете, делайте от души..."
    },
    {
      "reference": "1 Петра 5:7",
      "text": "Все заботы ваши возложите на Него..."
    },
    {
      "reference": "Исаия 40:31",
      "text": "А надеющиеся на Господа обновятся..."
    },
    {
      "reference": "Псалтирь 26:1",
      "text": "Господь — свет мой и спасение мое..."
    },
    {
      "reference": "Иоанна 8:32",
      "text": "И познаете истину, и истина сделает вас свободными."
    },
    {
      "reference": "Римлянам 6:23",
      "text": "Ибо возмездие за грех — смерть..."
