    },
    {
      "reference": "Евреям 13:8",
      "text": "Иисус Христос вчера и сегодня и во веки Тот же."
    },
    {
      "reference": "Иакова 4:7",
      "text": "Противостаньте диаволу, и убежит от вас."
    },
    {
      "reference": "2 Коринфянам 5:7",
      "text": "Мы ходим верою, а не видением."
    },
    {
      "reference": "Псалтирь 33:9",
      "text": "Вкусите и увидите, как благ Господь."
    },
    {
      "reference": "Псалтирь 36:4",
      "text": "Утешайся Господом."
    },
    {
      "reference": "Псалтирь 54:23",
      "text": "Возложи на Господа заботы твои."
    },
    {
      "reference": "Исаия 26:3",
      "text": "Твердого духом Ты хранишь в мире."
    },
    {
      "reference": "Исаия 55:8",
      "text": "Мои мысли — не ваши мысли."
    },
    {
      "reference": "Иеремия 33:3",
      "text": "Воззови ко Мне — и Я отвечу тебе."
    },
    {
      "reference": "Иезекииль 36:26",
      "text": "Дам вам сердце новое."
    },
    {
