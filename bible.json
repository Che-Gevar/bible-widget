    {
      "reference": "Матфея 6:34",
      "text": "Не заботьтесь о завтрашнем дне..."
    },
    {
      "reference": "Луки 1:37",
      "text": "У Бога не останется бессильным никакое слово."
    },
    {
      "reference": "Иоанна 16:33",
      "text": "Мужайтесь: Я победил мир."
    },
    {
      "reference": "Галатам 6:9",
      "text": "Делая добро, да не унываем."
    },
    {
      "reference": "Ефесянам 2:8",
